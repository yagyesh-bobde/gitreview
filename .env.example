# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth v5 (Auth.js)
# AUTH_SECRET is the canonical name; NEXTAUTH_SECRET also works as a fallback
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Database (Neon Postgres)
DATABASE_URL=

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI (Google Gemini)
GEMINI_API_KEY=

# Token Encryption (64-char hex string, 256 bits)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# GitHub OAuth (account linking flow)
# Create a second GitHub OAuth app for the "Link Account" flow.
# Callback URL: http://localhost:3000/api/auth/callback/github-link
GITHUB_LINK_CLIENT_ID=
GITHUB_LINK_CLIENT_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
